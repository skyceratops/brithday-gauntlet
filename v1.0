<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>BIRTHDAY TRUTH OR DARE</title>
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background: #0a0a1a;
            color: #00ff41;
            font-family: 'Press Start 2P', monospace;
            min-height: 100vh;
            min-height: 100dvh;
            overflow: hidden;
            touch-action: manipulation;
            -webkit-user-select: none;
            user-select: none;
        }

        #app {
            display: flex;
            flex-direction: column;
            height: 100vh;
            height: 100dvh;
            width: 100vw;
            max-width: 500px;
            margin: 0 auto;
            position: relative;
        }

        #tracker {
            display: none;
            justify-content: space-between;
            align-items: center;
            padding: 12px 16px;
            background: #111128;
            border-bottom: 3px solid #00ff41;
            font-size: 10px;
            line-height: 1.4;
            flex-shrink: 0;
            z-index: 50;
        }
        #tracker.visible { display: flex; }
        #tracker .money { color: #ffd700; }

        #screen {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 20px;
            text-align: center;
            overflow-y: auto;
            position: relative;
        }

        h1 { font-size: 20px; line-height: 1.6; margin-bottom: 20px; }
        h2 { font-size: 14px; line-height: 1.6; margin-bottom: 16px; }
        p, .desc { font-size: 10px; line-height: 1.8; color: #8888aa; margin-bottom: 14px; }

        .btn {
            font-family: 'Press Start 2P', monospace;
            font-size: 14px;
            padding: 16px 32px;
            border: 3px solid #00ff41;
            background: transparent;
            color: #00ff41;
            cursor: pointer;
            margin: 8px;
            transition: all 0.2s;
            min-width: 200px;
            text-transform: uppercase;
        }
        .btn:active { background: #00ff41; color: #0a0a1a; transform: scale(0.95); }
        .btn.truth { border-color: #00aaff; color: #00aaff; }
        .btn.truth:active { background: #00aaff; color: #0a0a1a; }
        .btn.dare { border-color: #ff4444; color: #ff4444; }
        .btn.dare:active { background: #ff4444; color: #0a0a1a; }

        .btn.answer {
            font-size: 9px;
            padding: 12px 16px;
            min-width: 280px;
            text-align: left;
            line-height: 1.5;
        }

        .float-up {
            position: fixed;
            top: 40%;
            left: 50%;
            transform: translateX(-50%);
            font-size: 48px;
            color: #ffd700;
            animation: floatUp 1.5s ease-out forwards;
            z-index: 100;
            pointer-events: none;
        }
        @keyframes floatUp {
            0% { opacity: 1; transform: translateX(-50%) translateY(0) scale(1); }
            100% { opacity: 0; transform: translateX(-50%) translateY(-120px) scale(1.3); }
        }

        .rip {
            position: fixed;
            top: 35%;
            left: 50%;
            transform: translateX(-50%);
            font-size: 64px;
            color: #ff4444;
            animation: ripShake 1.2s ease-out forwards;
            z-index: 100;
            pointer-events: none;
        }
        @keyframes ripShake {
            0% { opacity: 1; transform: translateX(-50%) scale(0.5); }
            20% { transform: translateX(-45%) scale(1.1); }
            40% { transform: translateX(-55%) scale(1); }
            60% { transform: translateX(-48%) scale(1.05); }
            80% { opacity: 1; transform: translateX(-52%) scale(1); }
            100% { opacity: 0; transform: translateX(-50%) scale(0.8); }
        }

        .timer-bar { width: 100%; height: 8px; background: #222; border: 1px solid #00ff41; margin: 10px 0; }
        .timer-bar-inner { height: 100%; background: #00ff41; transition: width 0.1s linear; }
        .timer-bar-inner.warning { background: #ff4444; }

        .game-hud { width: 100%; display: flex; justify-content: space-between; font-size: 10px; margin-bottom: 6px; }

        .simon-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; width: 260px; margin: 16px auto; }
        .simon-btn {
            height: 100px; border: 3px solid rgba(255,255,255,0.3);
            border-radius: 8px; cursor: pointer; opacity: 0.5;
            transition: opacity 0.15s, transform 0.1s;
        }
        .simon-btn.flash, .simon-btn:active { opacity: 1; transform: scale(1.05); border-color: white; }
        .simon-btn.c0 { background: #ff4444; }
        .simon-btn.c1 { background: #00cc44; }
        .simon-btn.c2 { background: #4488ff; }
        .simon-btn.c3 { background: #ffcc00; }

        .tap-target {
            width: 160px; height: 160px; border-radius: 50%;
            cursor: pointer; transition: transform 0.08s;
            display: flex; align-items: center; justify-content: center;
            background-size: cover; background-position: center;
        }
        .tap-target:active { transform: scale(0.88); }

        .math-problem { font-size: 28px; color: #ffd700; margin: 14px 0; }
        .math-answers { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; width: 100%; max-width: 300px; }
        .math-answers .btn { min-width: auto; font-size: 16px; padding: 14px; }

        .result-row {
            display: flex; align-items: center; justify-content: space-between;
            width: 100%; max-width: 340px; padding: 6px 0;
            font-size: 7px; line-height: 1.5; border-bottom: 1px solid #222;
        }
        .result-row .check { color: #00ff41; }
        .result-row .cross { color: #ff4444; }

        .final-total { font-size: 36px; color: #ffd700; margin: 20px 0; }

        .secret-code {
            color: #ff44ff; font-size: 12px; line-height: 2;
            margin: 16px 0; padding: 16px; border: 3px dashed #ff44ff;
        }

        .forced-msg {
            color: #ff8844; font-size: 10px; line-height: 1.8;
            margin: 12px 0; padding: 16px; border: 2px solid #ff8844;
        }

        .blink { animation: blink 1s step-end infinite; }
        @keyframes blink { 50% { opacity: 0; } }

        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        .fade-in { animation: fadeIn 0.3s ease-in; }

        /* Dramatic transition overlay */
        #overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0); z-index: 200;
            display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            pointer-events: none; transition: background 0.5s;
        }
        #overlay.active { background: rgba(0,0,0,0.92); pointer-events: all; }
        #overlay .overlay-text {
            font-family: 'Press Start 2P', monospace;
            font-size: 14px; color: #ffd700;
            opacity: 0; transition: opacity 0.4s;
            text-align: center; line-height: 2;
            padding: 20px;
        }
        #overlay .overlay-text.show { opacity: 1; }

        /* Countdown */
        .countdown {
            font-size: 72px; color: #ffd700;
            animation: countPulse 0.8s ease-out;
        }
        @keyframes countPulse {
            0% { transform: scale(2); opacity: 0; }
            50% { transform: scale(1); opacity: 1; }
            90% { opacity: 1; }
            100% { opacity: 0; transform: scale(0.8); }
        }

        .countdown-go {
            font-size: 48px; color: #00ff41;
            animation: countPulse 0.6s ease-out;
        }
    </style>
</head>
<body>
    <div id="app">
        <div id="tracker">
            <span id="challengeNum">CHALLENGE 1/10</span>
            <span class="money" id="moneyDisplay">$0</span>
        </div>
        <div id="screen"></div>
    </div>
    <div id="overlay"><div class="overlay-text" id="overlayText"></div></div>

<script>
// ================================================================
//  FACE IMAGES (base64 embedded)
// ================================================================
const JASON_FACE_URL = 'data:image/png;base64,';
const JOSH_FACE_URL = 'data:image/png;base64,';

let jasonImg = new Image();
jasonImg.src = JASON_FACE_URL;
let joshImg = new Image();
joshImg.src = JOSH_FACE_URL;

// ================================================================
//  CONFIGURATION — Adjust difficulty for each mini game!
// ================================================================
const CONFIG = {
    tapFrenzy: {
        duration: 8,        // seconds (was 6, +2)
        threshold: 20,      // taps needed (was 15, +5)
    },
    catchGame: {
        duration: 23,       // seconds (was 18, +5)
        spawnInterval: 1.2, // seconds between falling faces
        fallSpeed: 2.2,     // pixels per frame
        catchThreshold: 10, // faces needed (was 8, +2)
    },
    simonSays: {
        winLength: 5,       // rounds (was 4, +1)
        flashSpeed: 550,    // ms each color flashes
        pauseBetween: 220,  // ms gap between flashes
    },
    quickMath: {
        duration: 30,       // seconds (was 25, +5)
        threshold: 7,       // correct needed (was 5, +2)
        maxNumber: 12,
    },
    faceInvaders: {
        duration: 25,       // seconds (was 20, +5)
        maxMisses: 5,
        spawnInterval: 1.4, // slightly faster spawns
        fallSpeed: 1.4,     // slightly faster
        bulletSpeed: 7,
    },
};

// ================================================================
//  TRIVIA
// ================================================================
const TRIVIA = [
    { question: "What was Skyler's nickname as a child?", answers: ["Bum", "Antonio", "Beef", "Skyguy"], correct: 2 },
    { question: "What is Laetitia's middle name?", answers: ["Angelique-Louise", "Maria", "Juliette-Marie", "Frenchie-McFrenchface"], correct: 0 },
    { question: "What did Linken do as a child when he got shy?", answers: ["Run away", "Cry", "Throw up", "Pass out"], correct: 3 },
    { question: "Which uncle was the 2nd fastest sprinter in the state?", answers: ["Aaron", "Karston", "Skyler", "Jason"], correct: 3 },
    { question: "Which of the following is NOT a name of one of our chickens?", answers: ["Oreo", "Rosy", "Sunny", "Chunky"], correct: 1 },
];

// ================================================================
//  SECRET CODES
// ================================================================
const SECRET_CODES = {
    0: null, 2: "GO", 4: "BEEF", 6: "CHUNKY", 8: "BEEFDUDE",
    10: "BEEFMASTER", 12: "BEEFSUPERMAN", 14: "BEEFCAKELEGEND",
    16: "ULTIMATEBEEFCAKE", 18: "LEGENDARYBEEFCAKES", 20: "SUPREMEBEEFCAKECHAMP",
};

// ================================================================
//  SNARKY MESSAGES
// ================================================================
const SUCCESS_QUIPS = [
    "Yaaay. You're stealing more of my money.",
    "Fine. Take your $2. See if I care.",
    "Oh good. You CAN do things. Noted.",
    "Congrats. My wallet just shed a single tear.",
    "Well well well. Look who actually tried.",
    "That was almost impressive. Almost.",
    "Okay that was legitimately decent. Don't let it go to your head.",
    "Great. Another $2 I'll never see again.",
    "You're really out here earning this birthday money huh.",
    "I'm not mad. I'm just... $2 poorer.",
    "My bank account felt that one.",
    "Wow you actually did it. I had my doubts. Real ones.",
    "And just like that, my retirement fund takes another hit.",
    "Cool cool cool. This is fine. Everything is fine.",
    "You know that money was gonna go toward my therapy right.",
];

const FAIL_QUIPS = [
    "That was... genuinely hard to watch.",
    "We'll pretend that didn't happen. For both our sakes.",
    "Wow. I mean. Wow.",
    "Your ancestors just looked away in unison.",
    "The bar was on the floor and somehow you found a shovel.",
    "Honestly impressive how badly that went.",
    "The $2 you didn't earn just breathed a sigh of relief.",
    "You tried. And that's what matters. (It's not.)",
    "Birthday luck has officially left the building.",
    "That challenge had a family. You let them all down.",
    "I almost feel bad. Almost. Not quite.",
    "This is the kind of performance that builds character.",
    "Free money. All you had to do was try. And yet.",
    "I'll be telling this story at Thanksgiving.",
    "Don't worry. $0 is also a number.",
];

const FORCE_TRUTH_MSGS = [
    "Cute. You chose {chosen}. Too bad. You're getting TRUTH. It may be your birthday, but I make the rules.",
    "Oh you want {chosen}? That's adorable. TRUTH it is. I don't negotiate with birthday people.",
    "{chosen}? Sorry, that's out of stock. All we have left is TRUTH. Should've planned better.",
    "You picked {chosen}. The audacity. You're getting TRUTH whether you like it or not.",
    "Nice try picking {chosen}. Unfortunately, fate (me) has decided it's TRUTH time.",
];

const FORCE_DARE_MSGS = [
    "Cute. You chose {chosen}. Too bad. You're getting DARE. Your birthday means nothing here.",
    "{chosen}? Ha. No. DARE. The universe has spoken and it sounds a lot like me.",
    "You want {chosen}? That's sweet. You're getting DARE though. Life isn't fair. Neither am I.",
    "{chosen} is gone. Depleted. Extinct. All that's left is DARE and disappointment.",
    "Oh {chosen}? Sorry, we're fresh out. DARE it is. Consider it a character-building exercise.",
];

// ================================================================
//  GAME STATE
// ================================================================
let state = {};
let activeTimers = [];
let activeAnimFrame = null;

function resetState() {
    state = {
        currentChallenge: 0, earnings: 0, truthsUsed: 0, daresUsed: 0,
        results: [],
        truthQueue: shuffle([0, 1, 2, 3, 4]),
        dareQueue: shuffle(['tapFrenzy', 'catchGame', 'simonSays', 'quickMath', 'faceInvaders']),
    };
}

// ================================================================
//  UTILITIES
// ================================================================
function shuffle(arr) {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
}
function rand(lo, hi) { return Math.floor(Math.random() * (hi - lo + 1)) + lo; }
function pick(arr) { return arr[Math.floor(Math.random() * arr.length)]; }
const $ = sel => document.querySelector(sel);

function clearAllTimers() {
    activeTimers.forEach(id => { clearInterval(id); clearTimeout(id); });
    activeTimers = [];
    if (activeAnimFrame) { cancelAnimationFrame(activeAnimFrame); activeAnimFrame = null; }
    window._mathAnswer = null;
}
function addTimer(id) { activeTimers.push(id); return id; }

function updateTracker() {
    $('#challengeNum').textContent = `CHALLENGE ${Math.min(state.currentChallenge + 1, 10)}/10`;
    $('#moneyDisplay').textContent = `$${state.earnings}`;
}
function showTracker(vis) { $('#tracker').className = vis ? 'visible' : ''; }

// Draw face on canvas using specified image
function drawFace(ctx, x, y, size, img) {
    const faceImg = img || jasonImg;
    if (faceImg && faceImg.complete && faceImg.naturalWidth > 0) {
        ctx.save();
        ctx.beginPath();
        ctx.arc(x + size / 2, y + size / 2, size / 2, 0, Math.PI * 2);
        ctx.clip();
        ctx.drawImage(faceImg, x, y, size, size);
        ctx.restore();
    }
}

function createFaceDataURL(size, img) {
    const c = document.createElement('canvas');
    c.width = size; c.height = size;
    drawFace(c.getContext('2d'), 0, 0, size, img);
    return c.toDataURL();
}

// ================================================================
//  DRAMATIC TRANSITION
// ================================================================
function dramaticChoice(chosenType, forcedType, forceMsg, callback) {
    const overlay = $('#overlay');
    const text = $('#overlayText');

    overlay.className = 'active';
    text.className = 'overlay-text';
    text.innerHTML = '';

    // Step 1: show "you have chosen..."
    setTimeout(() => {
        const color = chosenType === 'TRUTH' ? '#00aaff' : '#ff4444';
        text.innerHTML = `<span style="color:${color}; font-size:20px;">YOU HAVE CHOSEN<br><br>${chosenType}</span>`;
        text.className = 'overlay-text show';
    }, 400);

    if (forcedType && forcedType !== chosenType) {
        // Step 2: force message
        setTimeout(() => {
            text.innerHTML = `<span style="color:#ff8844; font-size:10px; line-height:2;">${forceMsg}</span>`;
        }, 1800);
        setTimeout(() => {
            overlay.className = '';
            text.className = 'overlay-text';
            callback(forcedType);
        }, 4200);
    } else {
        // Step 2: proceed normally
        setTimeout(() => {
            overlay.className = '';
            text.className = 'overlay-text';
            callback(chosenType);
        }, 1800);
    }
}

// ================================================================
//  COUNTDOWN BEFORE MINI GAMES
// ================================================================
function showCountdown(callback) {
    let count = 3;
    const scr = $('#screen');
    function tick() {
        if (count > 0) {
            scr.innerHTML = `<div class="countdown">${count}</div>`;
            count--;
            addTimer(setTimeout(tick, 800));
        } else {
            scr.innerHTML = `<div class="countdown-go">GO!</div>`;
            addTimer(setTimeout(callback, 500));
        }
    }
    tick();
}

// ================================================================
//  WELCOME SCREEN
// ================================================================
function showWelcome() {
    showTracker(false);
    $('#screen').innerHTML = `
        <div class="fade-in">
            <h1>IT IS YOUR<br>BIRTHDAY.</h1>
            <p>Congratulations on continuing to exist. Truly an achievement for the ages. As a reward, you are being given the once-in-a-lifetime opportunity to earn your birthday money from yours truly.</p>
            <p>That's right. It's not free. Nothing in this life is, kid. You will complete 10 challenges. Each one you pass is worth $2. Each one you fail earns you absolutely nothing except my quiet judgment.</p>
            <p>Choose between TRUTH (family trivia that proves you pay attention at holidays) or DARE (mini games that require the bare minimum of hand-eye coordination).</p>
            <p>Your destiny is technically in your hands now. Try not to fumble it.</p>
            <br>
            <button class="btn" onclick="startGame()">I ACCEPT MY FATE</button>
            <p class="blink" style="margin-top:16px; font-size:8px;">► PRESS START</p>
        </div>
    `;
}

function startGame() {
    showTracker(true);
    updateTracker();
    showChooseScreen();
}

// ================================================================
//  CHOOSE SCREEN
// ================================================================
function showChooseScreen() {
    clearAllTimers();
    updateTracker();
    if (state.currentChallenge >= 10) { showFinalSummary(); return; }

    const truthLeft = 5 - state.truthsUsed;
    const dareLeft = 5 - state.daresUsed;

    // Determine what type will actually be forced (if any)
    let forceTruth = truthLeft <= 0;
    let forceDare = dareLeft <= 0;

    window._chooseType = function(chosen) {
        let actualType = chosen;
        let forceMsg = null;

        if (chosen === 'TRUTH' && forceTruth) {
            actualType = 'DARE';
            forceMsg = pick(FORCE_DARE_MSGS).replace('{chosen}', 'TRUTH');
        } else if (chosen === 'DARE' && forceDare) {
            actualType = 'TRUTH';
            forceMsg = pick(FORCE_TRUTH_MSGS).replace('{chosen}', 'DARE');
        } else if (chosen === 'TRUTH' && forceDare) {
            actualType = 'TRUTH'; // this is fine
        } else if (chosen === 'DARE' && forceTruth) {
            actualType = 'DARE'; // this is fine
        }

        dramaticChoice(chosen, actualType, forceMsg, function(finalType) {
            if (finalType === 'TRUTH') startTruth();
            else startDare();
        });
    };

    const snarkyHeaders = [
        "Choose. But choose wisely. Just kidding. It barely matters.",
        "Pick your poison. Both options lead to me losing money.",
        "The illusion of free will. You're welcome.",
        "Decisions, decisions. Try not to overthink it.",
        "One of these earns you $2. The other also might. No pressure.",
        "This choice will define you as a person. (It won't.)",
        "Choose with your heart. Or your gut. Or just tap randomly.",
        "The fate of $2 hangs in the balance.",
        "Make a choice before I make it for you.",
        "Tick tock. That $2 isn't going to earn itself.",
    ];

    $('#screen').innerHTML = `
        <div class="fade-in">
            <h2>CHALLENGE ${state.currentChallenge + 1} OF 10</h2>
            <p>${pick(snarkyHeaders)}</p>
            <br>
            <button class="btn truth" onclick="window._chooseType('TRUTH')" style="font-size:18px; padding:24px 48px;">TRUTH</button>
            <br>
            <button class="btn dare" onclick="window._chooseType('DARE')" style="font-size:18px; padding:24px 48px;">DARE</button>
        </div>
    `;
}

// ================================================================
//  TRUTH — TRIVIA
// ================================================================
function startTruth() {
    clearAllTimers();
    const qi = state.truthQueue[state.truthsUsed];
    const q = TRIVIA[qi];
    state.truthsUsed++;
    let answered = false;

    window._answerTruth = function(sel) {
        if (answered) return;
        answered = true;
        const btns = document.querySelectorAll('.answer-btn');
        btns.forEach((b, i) => {
            if (i === q.correct) b.style.borderColor = b.style.color = '#00ff41';
            else if (i === sel && sel !== q.correct) b.style.borderColor = b.style.color = '#ff4444';
            b.style.pointerEvents = 'none';
        });
        addTimer(setTimeout(() => recordResult('TRUTH', sel === q.correct, q.question.substring(0, 28) + '...'), 900));
    };

    $('#screen').innerHTML = `
        <div class="fade-in">
            <h2 style="color:#00aaff;">► TRUTH</h2>
            <p style="color:#ddd; font-size:11px; line-height:2;">${q.question}</p>
            <br>
            <div style="display:flex; flex-direction:column; align-items:center; width:100%;">
                ${q.answers.map((a, i) => `
                    <button class="btn answer answer-btn" onclick="window._answerTruth(${i})">${String.fromCharCode(65 + i)}. ${a}</button>
                `).join('')}
            </div>
        </div>
    `;
}

// ================================================================
//  DARE — DISPATCHER
// ================================================================
function startDare() {
    clearAllTimers();
    const game = state.dareQueue[state.daresUsed];
    state.daresUsed++;

    // Show countdown THEN launch the game
    showCountdown(() => {
        switch (game) {
            case 'tapFrenzy':    launchTapFrenzy(); break;
            case 'catchGame':    launchCatchGame(); break;
            case 'simonSays':    launchSimonSays(); break;
            case 'quickMath':    launchQuickMath(); break;
            case 'faceInvaders': launchFaceInvaders(); break;
        }
    });
}

// ================================================================
//  DARE 1: TAP FRENZY (uses Josh image)
// ================================================================
function launchTapFrenzy() {
    const cfg = CONFIG.tapFrenzy;
    let taps = 0, started = false, done = false, timeLeft = cfg.duration;
    const faceURL = createFaceDataURL(160, joshImg);

    $('#screen').innerHTML = `
        <div class="fade-in">
            <h2 style="color:#ff4444;">► TAP FRENZY</h2>
            <div class="game-hud">
                <span>TAPS: <span id="gTaps">0</span>/${cfg.threshold}</span>
                <span>TIME: <span id="gTime">${cfg.duration.toFixed(1)}</span>s</span>
            </div>
            <div class="timer-bar"><div class="timer-bar-inner" id="gBar" style="width:100%"></div></div>
            <p>Tap the face. A lot. Aggressively.</p>
            <br>
            <div class="tap-target" id="tapTarget" style="background-image:url(${faceURL});"></div>
            <p id="tapHint" style="margin-top:12px; font-size:8px;" class="blink">TAP FACE TO START</p>
        </div>
    `;

    let interval;
    $('#tapTarget').addEventListener('pointerdown', function handler(e) {
        e.preventDefault();
        if (done) return;
        if (!started) {
            started = true;
            const hint = $('#tapHint'); if (hint) hint.remove();
            interval = addTimer(setInterval(() => {
                timeLeft -= 0.1;
                if (timeLeft <= 0) {
                    timeLeft = 0; done = true; clearInterval(interval);
                    recordResult('DARE', taps >= cfg.threshold, 'TAP FRENZY');
                    return;
                }
                const el = $('#gTime'); if (el) el.textContent = timeLeft.toFixed(1);
                const pct = (timeLeft / cfg.duration) * 100;
                const bar = $('#gBar');
                if (bar) { bar.style.width = pct + '%'; if (pct < 25) bar.className = 'timer-bar-inner warning'; }
            }, 100));
        }
        taps++;
        const el = $('#gTaps'); if (el) el.textContent = taps;
        if (taps >= cfg.threshold) {
            done = true; clearInterval(interval);
            addTimer(setTimeout(() => recordResult('DARE', true, 'TAP FRENZY'), 300));
        }
    });
}

// ================================================================
//  DARE 2: CATCH THE FALLING FACES (uses Jason image)
// ================================================================
function launchCatchGame() {
    const cfg = CONFIG.catchGame;
    let caught = 0, done = false, faces = [], basketX = 0.5;

    $('#screen').innerHTML = `
        <div class="fade-in" style="width:100%;">
            <h2 style="color:#ff4444;">► CATCH THE FACES</h2>
            <div class="game-hud">
                <span>CAUGHT: <span id="gCaught">0</span>/${cfg.catchThreshold}</span>
                <span>TIME: <span id="gTime">${cfg.duration.toFixed(1)}</span>s</span>
            </div>
            <div class="timer-bar"><div class="timer-bar-inner" id="gBar" style="width:100%"></div></div>
            <p style="font-size:8px; margin-bottom:6px;">DRAG TO MOVE BASKET</p>
            <canvas id="gCanvas" style="display:block; margin:0 auto; border:2px solid #00ff41; background:#0d0d24; touch-action:none;"></canvas>
        </div>
    `;

    const canvas = $('#gCanvas');
    const w = Math.min(440, window.innerWidth - 48);
    const h = Math.min(320, window.innerHeight - 280);
    canvas.width = w; canvas.height = h;
    canvas.style.width = w + 'px'; canvas.style.height = h + 'px';
    const ctx = canvas.getContext('2d');
    const basketW = 70, basketH = 16, faceSize = 34;

    function handleMove(cx) {
        const r = canvas.getBoundingClientRect();
        basketX = Math.max(0, Math.min(1, (cx - r.left) / r.width));
    }
    canvas.addEventListener('touchmove', e => { e.preventDefault(); handleMove(e.touches[0].clientX); }, { passive: false });
    canvas.addEventListener('touchstart', e => { e.preventDefault(); handleMove(e.touches[0].clientX); }, { passive: false });
    canvas.addEventListener('mousemove', e => handleMove(e.clientX));

    const startTime = performance.now();
    let lastSpawn = -cfg.spawnInterval;

    function loop() {
        if (done) return;
        const elapsed = (performance.now() - startTime) / 1000;
        const timeLeft = Math.max(0, cfg.duration - elapsed);
        const tEl = $('#gTime'); if (tEl) tEl.textContent = timeLeft.toFixed(1);
        const pct = (timeLeft / cfg.duration) * 100;
        const bEl = $('#gBar');
        if (bEl) { bEl.style.width = pct + '%'; if (pct < 25) bEl.className = 'timer-bar-inner warning'; }

        if (elapsed - lastSpawn >= cfg.spawnInterval) {
            faces.push({ x: Math.random() * (w - faceSize), y: -faceSize, alive: true });
            lastSpawn = elapsed;
        }
        const bx = basketX * w - basketW / 2, by = h - basketH - 6;
        faces.forEach(f => {
            if (!f.alive) return;
            f.y += cfg.fallSpeed;
            if (f.y + faceSize >= by && f.y <= by + basketH && f.x + faceSize > bx && f.x < bx + basketW) {
                f.alive = false; caught++;
                const cEl = $('#gCaught'); if (cEl) cEl.textContent = caught;
            }
            if (f.y > h + faceSize) f.alive = false;
        });
        faces = faces.filter(f => f.alive);

        ctx.clearRect(0, 0, w, h);
        ctx.fillStyle = '#00ff41';
        ctx.fillRect(bx, by, basketW, basketH);
        ctx.fillStyle = '#005511';
        ctx.fillRect(bx + 3, by + 3, basketW - 6, basketH - 6);
        faces.forEach(f => drawFace(ctx, f.x, f.y, faceSize, jasonImg));

        if (caught >= cfg.catchThreshold) {
            done = true;
            addTimer(setTimeout(() => recordResult('DARE', true, 'CATCH THE FACES'), 400));
            return;
        }
        if (timeLeft <= 0) {
            done = true;
            addTimer(setTimeout(() => recordResult('DARE', caught >= cfg.catchThreshold, 'CATCH THE FACES'), 400));
            return;
        }
        activeAnimFrame = requestAnimationFrame(loop);
    }
    activeAnimFrame = requestAnimationFrame(loop);
}

// ================================================================
//  DARE 3: SIMON SAYS
// ================================================================
function launchSimonSays() {
    const cfg = CONFIG.simonSays;
    const sequence = Array.from({ length: cfg.winLength }, () => Math.floor(Math.random() * 4));
    let round = 1, playerInput = [], showing = false, done = false;

    $('#screen').innerHTML = `
        <div class="fade-in">
            <h2 style="color:#ff4444;">► SIMON SAYS</h2>
            <p id="gStatus">Watch the pattern...</p>
            <p id="gRound" style="color:#ffd700; font-size:9px;">ROUND 1 / ${cfg.winLength}</p>
            <div class="simon-grid">
                <div class="simon-btn c0" data-c="0"></div>
                <div class="simon-btn c1" data-c="1"></div>
                <div class="simon-btn c2" data-c="2"></div>
                <div class="simon-btn c3" data-c="3"></div>
            </div>
        </div>
    `;

    const btns = document.querySelectorAll('.simon-btn');
    btns.forEach(btn => {
        btn.addEventListener('pointerdown', e => {
            e.preventDefault();
            if (showing || done) return;
            const c = parseInt(btn.dataset.c);
            btn.classList.add('flash');
            setTimeout(() => btn.classList.remove('flash'), 200);
            playerInput.push(c);
            const idx = playerInput.length - 1;

            if (playerInput[idx] !== sequence[idx]) {
                done = true;
                $('#gStatus').textContent = 'WRONG.'; $('#gStatus').style.color = '#ff4444';
                addTimer(setTimeout(() => recordResult('DARE', false, 'SIMON SAYS'), 800));
                return;
            }
            if (playerInput.length === round) {
                if (round === cfg.winLength) {
                    done = true;
                    $('#gStatus').textContent = 'PERFECT.'; $('#gStatus').style.color = '#00ff41';
                    addTimer(setTimeout(() => recordResult('DARE', true, 'SIMON SAYS'), 800));
                    return;
                }
                round++; playerInput = [];
                $('#gRound').textContent = `ROUND ${round} / ${cfg.winLength}`;
                addTimer(setTimeout(() => playSeq(round), 500));
            }
        });
    });

    function playSeq(n) {
        showing = true;
        $('#gStatus').textContent = 'Watch...';
        let i = 0;
        function next() {
            if (i >= n) { showing = false; $('#gStatus').textContent = 'Your turn!'; return; }
            btns[sequence[i]].classList.add('flash');
            addTimer(setTimeout(() => {
                btns[sequence[i]].classList.remove('flash');
                i++;
                addTimer(setTimeout(next, cfg.pauseBetween));
            }, cfg.flashSpeed));
        }
        addTimer(setTimeout(next, 350));
    }
    addTimer(setTimeout(() => playSeq(1), 700));
}

// ================================================================
//  DARE 4: QUICK MATH
// ================================================================
function launchQuickMath() {
    const cfg = CONFIG.quickMath;
    let correct = 0, done = false, timeLeft = cfg.duration;

    function makeProblem() {
        const ops = ['+', '-', '\u00d7'];
        const op = ops[Math.floor(Math.random() * 3)];
        let a, b, ans;
        if (op === '+') { a = rand(1, cfg.maxNumber); b = rand(1, cfg.maxNumber); ans = a + b; }
        else if (op === '-') { a = rand(2, cfg.maxNumber); b = rand(1, a); ans = a - b; }
        else { a = rand(2, 9); b = rand(2, 9); ans = a * b; }
        const wrongs = new Set();
        while (wrongs.size < 3) {
            const w = ans + rand(-5, 5);
            if (w !== ans && w >= 0) wrongs.add(w);
        }
        let opts = shuffle([ans, ...wrongs]);
        return { text: `${a} ${op} ${b}`, ans, opts, ci: opts.indexOf(ans) };
    }

    window._mathAnswer = function(sel, ci) {
        if (done) return;
        if (sel === ci) {
            correct++;
            const el = $('#gCorrect'); if (el) el.textContent = correct;
            if (correct >= cfg.threshold) {
                done = true;
                recordResult('DARE', true, 'QUICK MATH');
                return;
            }
        }
        showProblem();
    };

    function showProblem() {
        const p = makeProblem();
        const area = $('#mathArea');
        if (!area) return;
        area.innerHTML = `
            <div class="math-problem">${p.text} = ?</div>
            <div class="math-answers">
                ${p.opts.map((o, i) => `<button class="btn" onclick="window._mathAnswer(${i},${p.ci})">${o}</button>`).join('')}
            </div>
        `;
    }

    $('#screen').innerHTML = `
        <div class="fade-in" style="width:100%;">
            <h2 style="color:#ff4444;">► QUICK MATH</h2>
            <div class="game-hud">
                <span>CORRECT: <span id="gCorrect">0</span>/${cfg.threshold}</span>
                <span>TIME: <span id="gTime">${cfg.duration.toFixed(1)}</span>s</span>
            </div>
            <div class="timer-bar"><div class="timer-bar-inner" id="gBar" style="width:100%"></div></div>
            <div id="mathArea" style="margin-top:10px;"></div>
        </div>
    `;
    showProblem();

    const iv = addTimer(setInterval(() => {
        if (done) { clearInterval(iv); return; }
        timeLeft -= 0.1;
        if (timeLeft <= 0) {
            done = true; clearInterval(iv);
            recordResult('DARE', correct >= cfg.threshold, 'QUICK MATH');
            return;
        }
        const el = $('#gTime'); if (el) el.textContent = timeLeft.toFixed(1);
        const pct = (timeLeft / cfg.duration) * 100;
        const bar = $('#gBar');
        if (bar) { bar.style.width = pct + '%'; if (pct < 25) bar.className = 'timer-bar-inner warning'; }
    }, 100));
}

// ================================================================
//  DARE 5: FACE INVADERS (uses Jason image)
// ================================================================
function launchFaceInvaders() {
    const cfg = CONFIG.faceInvaders;
    let misses = 0, done = false, faces = [], bullets = [], cannonX = 0.5;

    $('#screen').innerHTML = `
        <div class="fade-in" style="width:100%;">
            <h2 style="color:#ff4444;">► FACE INVADERS</h2>
            <div class="game-hud">
                <span>MISSES: <span id="gMisses">0</span>/${cfg.maxMisses}</span>
                <span>TIME: <span id="gTime">${cfg.duration.toFixed(1)}</span>s</span>
            </div>
            <div class="timer-bar"><div class="timer-bar-inner" id="gBar" style="width:100%"></div></div>
            <p style="font-size:8px; margin-bottom:6px;">TAP TO AIM & SHOOT</p>
            <canvas id="gCanvas" style="display:block; margin:0 auto; border:2px solid #ff4444; background:#0d0d24; touch-action:none;"></canvas>
        </div>
    `;

    const canvas = $('#gCanvas');
    const w = Math.min(440, window.innerWidth - 48);
    const h = Math.min(340, window.innerHeight - 280);
    canvas.width = w; canvas.height = h;
    canvas.style.width = w + 'px'; canvas.style.height = h + 'px';
    const ctx = canvas.getContext('2d');
    const faceSize = 34, cannonW = 28, cannonH = 18, bulletR = 4;

    canvas.addEventListener('pointerdown', e => {
        e.preventDefault();
        if (done) return;
        const rect = canvas.getBoundingClientRect();
        const tx = (e.clientX - rect.left) * (w / rect.width);
        const ty = (e.clientY - rect.top) * (h / rect.height);
        cannonX = Math.max(cannonW / w, Math.min(1 - cannonW / w, tx / w));
        const cx = cannonX * w, cy = h - cannonH - 6;
        const dx = tx - cx, dy = ty - cy;
        const d = Math.sqrt(dx * dx + dy * dy) || 1;
        const vy = Math.min(dy / d, -0.3) * cfg.bulletSpeed;
        const vx = (dx / d) * cfg.bulletSpeed;
        bullets.push({ x: cx, y: cy, vx, vy });
    });

    const startTime = performance.now();
    let lastSpawn = -cfg.spawnInterval;
    const stars = Array.from({ length: 40 }, () => ({ x: Math.random() * w, y: Math.random() * h, b: Math.random() }));

    function loop() {
        if (done) return;
        const elapsed = (performance.now() - startTime) / 1000;
        const timeLeft = Math.max(0, cfg.duration - elapsed);
        const tEl = $('#gTime'); if (tEl) tEl.textContent = timeLeft.toFixed(1);
        const pct = (timeLeft / cfg.duration) * 100;
        const bEl = $('#gBar');
        if (bEl) { bEl.style.width = pct + '%'; if (pct < 25) bEl.className = 'timer-bar-inner warning'; }

        if (elapsed - lastSpawn >= cfg.spawnInterval) {
            faces.push({ x: Math.random() * (w - faceSize), y: -faceSize, alive: true });
            lastSpawn = elapsed;
        }
        faces.forEach(f => {
            if (!f.alive) return;
            f.y += cfg.fallSpeed;
            if (f.y > h) {
                f.alive = false; misses++;
                const mEl = $('#gMisses'); if (mEl) mEl.textContent = misses;
            }
        });
        bullets.forEach(b => { b.x += b.vx; b.y += b.vy; });
        bullets = bullets.filter(b => b.y > -20 && b.y < h + 20 && b.x > -20 && b.x < w + 20);

        for (let bi = bullets.length - 1; bi >= 0; bi--) {
            for (let fi = faces.length - 1; fi >= 0; fi--) {
                const b = bullets[bi], f = faces[fi];
                if (!f || !f.alive) continue;
                if (b.x >= f.x - 6 && b.x <= f.x + faceSize + 6 && b.y >= f.y - 6 && b.y <= f.y + faceSize + 6) {
                    f.alive = false; bullets.splice(bi, 1); break;
                }
            }
        }
        faces = faces.filter(f => f.alive);

        ctx.clearRect(0, 0, w, h);
        stars.forEach(s => {
            const flicker = 0.4 + 0.6 * Math.sin(elapsed * 2 + s.b * 10);
            ctx.fillStyle = `rgba(255,255,255,${flicker * 0.3})`;
            ctx.fillRect(s.x, s.y, 2, 2);
        });
        const cx = cannonX * w;
        ctx.fillStyle = '#00ff41';
        ctx.fillRect(cx - cannonW / 2, h - cannonH - 6, cannonW, cannonH);
        ctx.fillRect(cx - 3, h - cannonH - 16, 6, 12);
        ctx.fillStyle = '#ffff00';
        bullets.forEach(b => { ctx.beginPath(); ctx.arc(b.x, b.y, bulletR, 0, Math.PI * 2); ctx.fill(); });
        faces.forEach(f => drawFace(ctx, f.x, f.y, faceSize, jasonImg));

        if (misses >= cfg.maxMisses) {
            done = true;
            addTimer(setTimeout(() => recordResult('DARE', false, 'FACE INVADERS'), 500));
            return;
        }
        if (timeLeft <= 0) {
            done = true;
            addTimer(setTimeout(() => recordResult('DARE', true, 'FACE INVADERS'), 500));
            return;
        }
        activeAnimFrame = requestAnimationFrame(loop);
    }
    activeAnimFrame = requestAnimationFrame(loop);
}

// ================================================================
//  RESULT SCREEN
// ================================================================
function recordResult(type, passed, label) {
    clearAllTimers();
    state.results.push({ type, passed, label });
    if (passed) state.earnings += 2;
    state.currentChallenge++;
    updateTracker();

    if (passed) {
        const el = document.createElement('div');
        el.className = 'float-up'; el.textContent = '+$2';
        document.body.appendChild(el);
        setTimeout(() => el.remove(), 1600);
        $('#screen').innerHTML = `
            <div class="fade-in">
                <h1 style="color:#00ff41; font-size:32px;">NICE.</h1>
                <p style="color:#00ff41;">${pick(SUCCESS_QUIPS)}</p>
                <p style="color:#ffd700; font-size:18px;">Total: $${state.earnings}</p>
            </div>
        `;
    } else {
        const el = document.createElement('div');
        el.className = 'rip'; el.textContent = 'RIP';
        document.body.appendChild(el);
        setTimeout(() => el.remove(), 1400);
        $('#screen').innerHTML = `
            <div class="fade-in">
                <h1 style="color:#ff4444; font-size:32px;">NOPE.</h1>
                <p style="color:#ff4444;">${pick(FAIL_QUIPS)}</p>
                <p style="color:#ffd700; font-size:18px;">Total: $${state.earnings}</p>
            </div>
        `;
    }

    if (state.currentChallenge >= 10) {
        addTimer(setTimeout(showFinalSummary, 2500));
    } else {
        addTimer(setTimeout(showChooseScreen, 2200));
    }
}

// ================================================================
//  FINAL SUMMARY
// ================================================================
function showFinalSummary() {
    clearAllTimers();
    showTracker(false);

    const rows = state.results.map((r, i) => `
        <div class="result-row">
            <span style="text-align:left;">#${i + 1} ${r.type}</span>
            <span class="${r.passed ? 'check' : 'cross'}">${r.passed ? '\u2713 $2' : '\u2717 $0'}</span>
        </div>
    `).join('');

    const code = SECRET_CODES[state.earnings];
    let codeHTML;
    if (code) {
        codeHTML = `<div class="secret-code">Tell Skyler the secret code:<br><br><span style="font-size:16px; letter-spacing:4px;">${code}</span></div>`;
    } else {
        codeHTML = `<div class="secret-code">Your secret code is:<br><br><span style="font-size:12px;">...nothing. You got $0. There is no code.<br>Just silence and the echo of what could have been.</span></div>`;
    }

    const closingSnark = state.earnings >= 16
        ? "Well played. You have successfully drained my finances. I hope you're proud."
        : state.earnings >= 10
        ? "Not bad. Not great. But not bad. You can sleep at night."
        : state.earnings >= 6
        ? "Could've been worse. Could've been a lot better too. Just saying."
        : state.earnings >= 2
        ? "That's... not a lot. At all. But hey, $2 buys you... part of a coffee?"
        : "Wow. $0. I don't even know what to say. Actually I do: yikes.";

    $('#screen').innerHTML = `
        <div class="fade-in">
            <h2>THE RESULTS ARE IN.</h2>
            <p>${closingSnark}</p>
            <br>
            ${rows}
            <div class="final-total">$${state.earnings}</div>
            <br>
            ${codeHTML}
            <br>
            <p style="font-size:8px; line-height:1.8;">Happy birthday, you absolute legend.</p>
        </div>
    `;
}

// ================================================================
//  BOOT
// ================================================================
resetState();
showWelcome();
</script>
</body>
</html>
